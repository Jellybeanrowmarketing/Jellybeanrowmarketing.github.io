&lt;style&gt;
:root{
  --bg:#212844;
  --bg-mid:#2a3355;
  --bg-light:#303d65;
  --cyan:#29b8e0;
  --cyan-bright:#3dd6f5;
  --white:#ffffff;
  --grey:#8a9bbf;
  --grey-light:#b0bed8;
  --gold:#f0a500;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--white);
  font-family:'Barlow',sans-serif;
  overflow-x:hidden;
}

/* =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D
   SPLASH =E2=80=94 full page, then reveals site
   =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:var(--bg);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:28px;
  /* starts visible, fades out */
  animation:splashExit 0.9s 2.4s ease forwards;
}
@keyframes splashExit{
  0%{opacity:1;visibility:visible;}
  99%{opacity:0;visibility:visible;}
  100%{opacity:0;visibility:hidden;pointer-events:none;}
}

/* rings expanding behind logo */
.sp-rings{
  position:absolute;
  display:flex;align-items:center;justify-content:center;
}
.sp-ring{
  position:absolute;border-radius:50%;
  border:1px solid rgba(41,184,224,0.2);
  animation:spRing 3s ease-in-out infinite;
}
.sp-ring:nth-child(1){width:260px;height:260px;animation-delay:0s;}
.sp-ring:nth-child(2){width:360px;height:360px;animation-delay:0.7s;}
.sp-ring:nth-child(3){width:460px;height:460px;animation-delay:1.4s;}
@keyframes spRing{
  0%,100%{opacity:0.15;transform:scale(1);}
  50%{opacity:0.5;transform:scale(1.03);}
}

/* logo scales + glows in */
.sp-logo{
  position:relative;z-index:2;
  opacity:0;
  animation:spLogoIn 1s 0.2s cubic-bezier(0.16,1,0.3,1) forwards;
}
@keyframes spLogoIn{
  from{opacity:0;transform:scale(0.3);}
  to{opacity:1;transform:scale(1);}
}
.sp-logo img{
  width:240px;
  animation:spLogoPulse 1.5s 1.2s ease-in-out infinite alternate;
}
@keyframes spLogoPulse{
  from{filter:drop-shadow(0 0 20px rgba(41,184,224,0.4));}
  to{filter:drop-shadow(0 0 60px rgba(41,184,224,0.9));}
}

/* progress bar */
.sp-bar-wrap{
  width:180px;height:2px;
  background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden;
  opacity:0;animation:fadeIn 0.4s 0.5s ease forwards;
}
.sp-bar{
  height:100%;
  background:linear-gradient(90deg,var(--white),var(--cyan));
  border-radius:2px;
  animation:barFill 1.8s 0.5s ease forwards;
}
@keyframes barFill{from{width:0%}to{width:100%}}
@keyframes fadeIn{to{opacity:1}}

/* =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D
   MAIN SITE =E2=80=94 hidden until splash exits
   =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D */
#site{
  opacity:0;
  animation:siteReveal 0.7s 2.6s ease forwards;
}
@keyframes siteReveal{
  from{opacity:0;}
  to{opacity:1;}
}

/* =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D
   NAV
   =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:16px 60px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(33,40,68,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(41,184,224,0.1);
}
.nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-logo{
  width:44px;height:44px;object-fit:contain;
  animation:navLogoSpin 0.9s 0.2s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes navLogoSpin{
  from{opacity:0;transform:rotate(-180deg) scale(0.2);}
  to{opacity:1;transform:rotate(0deg) scale(1);}
}
.nav-brand-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;f=
ont-size:14px;letter-spacing:2px;color:var(--white);}
.nav-brand-sub{font-family:'Barlow Condensed',sans-serif;font-weight:700;fo=
nt-size:9px;letter-spacing:4px;color:var(--cyan);}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{color:var(--grey);text-decoration:none;font-size:12px;font-wei=
ght:600;letter-spacing:1.5px;text-transform:uppercase;transition:color 0.25=
s;}
.nav-links a:hover{color:var(--white);}
.nav-cta{background:var(--cyan)!important;color:var(--bg)!important;padding=
:9px 22px;border-radius:2px;font-weight:700!important;}
.nav-cta:hover{background:var(--cyan-bright)!important;}

